#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
TOOL_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
CONFIG="$TOOL_DIR/config.json"
VAULT_PATH=${OBSIDIAN_VAULT_PATH:-$(jq -r '.vaultPath' "$CONFIG")}
TARGET_REL=$(jq -r '.runtimeTarget' "$CONFIG")
TARGET="$VAULT_PATH/$TARGET_REL"
MANIFEST="$VAULT_PATH/Scripts/localization/publisher-install.json"
README="$VAULT_PATH/Scripts/localization/README.md"
TERMINOLOGY="$VAULT_PATH/Scripts/localization/terminology.json"

mkdir -p "$(dirname -- "$TARGET")" "$(dirname -- "$MANIFEST")"
cp "$TOOL_DIR/publish-note.js" "$TARGET"
cp "$TOOL_DIR/vault-README.md" "$README"
cp "$TOOL_DIR/terminology.json" "$TERMINOLOGY"
HASH=$(shasum -a 256 "$TOOL_DIR/publish-note.js" | awk '{print $1}')
TERMINOLOGY_HASH=$(shasum -a 256 "$TOOL_DIR/terminology.json" | awk '{print $1}')
jq -n --arg hash "$HASH" --arg terminologyHash "$TERMINOLOGY_HASH" --arg source "$TOOL_DIR/publish-note.js" \
  '{runtimeVersion:"publisher-v1",sourceHash:$hash,terminologyHash:$terminologyHash,canonicalSource:$source}' > "$MANIFEST"
printf 'Installed publisher-v1 (%s)\n' "$HASH"
